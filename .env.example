# Google Gemini API Key
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Roboflow API Key — used for BOTH dataset download AND cloud inference
# Model: cricket-oftm6/3  (mAP 96.2%, 6 classes)
# Get/regenerate yours at: https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=your_roboflow_api_key

# HuggingFace Token — needed to download Cric-360 validation dataset
# Get yours at: https://huggingface.co/settings/tokens
# Then also run: huggingface-cli login
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Database URL (default: SQLite for POC)
DATABASE_URL=sqlite:///./data/cricket_intelligence.db
